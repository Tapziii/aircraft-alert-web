# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: set your chat ID manually. If not set, send /start to the bot and it will auto-detect.
TELEGRAM_CHAT_ID=

# How often to poll ADS-B APIs (in seconds)
POLL_INTERVAL=30

# Port for the HTTP API (extension syncs watchlist here)
PORT=3000
